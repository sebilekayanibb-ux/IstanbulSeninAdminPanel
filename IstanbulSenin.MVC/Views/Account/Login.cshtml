@model IstanbulSenin.MVC.Models.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "_LoginLayout";
}

<div class="card border-0 shadow-lg rounded-4 p-4" style="width: 420px;">
    <div class="text-center mb-4">
        <i class="bi bi-geo-alt-fill mb-2" style="font-size: 2.5rem; color: #FF007A;"></i>
        <h4 class="fw-800 mb-0" style="font-family: 'Plus Jakarta Sans', sans-serif;">İSTANBUL SENİN</h4>
        <p class="text-muted small mt-1">Admin Paneli</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger rounded-3 small py-2">
            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@err.ErrorMessage</div>
            }
        </div>
    }

    <form asp-action="Login" method="post">
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

        <div class="mb-3">
            <label asp-for="Email" class="form-label fw-bold small">E-posta</label>
            <input asp-for="Email" class="form-control rounded-3 bg-light border-0"
                   placeholder="admin@ibb.gov.tr" autofocus />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label fw-bold small">Şifre</label>
            <div class="input-group">
                <input asp-for="Password" id="passwordInput" class="form-control rounded-start-3 bg-light border-0"
                       placeholder="Şifrenizi Giriniz!" />
                <button type="button" class="btn btn-light border-0" id="togglePassword"
                        style="border-radius: 0 0.75rem 0.75rem 0;">
                    <i class="bi bi-eye" id="toggleIcon"></i>
                </button>
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="mb-4 d-flex align-items-center">
            <input asp-for="RememberMe" class="form-check-input me-2" type="checkbox" />
            <label asp-for="RememberMe" class="form-check-label small text-muted">Beni hatırla</label>
        </div>

        <button type="submit" class="btn w-100 fw-bold rounded-pill py-2"
                style="background: #FF007A; color: white;">
            <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
        </button>
    </form>
</div>

<script>
    document.getElementById('togglePassword').addEventListener('click', function () {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('toggleIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    });
</script>
