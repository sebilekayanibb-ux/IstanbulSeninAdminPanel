@model IstanbulSenin.BLL.Services.Dashboard.DashboardDto

@{
    ViewData["Title"] = "Dashboard - İstatistikler";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container-fluid mt-4">
    <!-- Başlık -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
        <div class="btn-group">
            <a href="@Url.Action("Index")" class="btn btn-outline-primary">Bu Hafta</a>
            <a href="@Url.Action("DateRange", new { startDate = DateTime.Now.AddDays(-30), endDate = DateTime.Now })" 
               class="btn btn-outline-primary">Son 30 Gün</a>
            <a href="/swagger" class="btn btn-outline-info" target="_blank">
                <i class="bi bi-puzzle"></i> API Docs
            </a>
        </div>
    </div>

    <!-- İstatistik Kartları -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-uppercase mb-2">Toplam Bildirim</h6>
                    <h2 class="mb-0">@Model.TotalNotifications</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-uppercase mb-2">Gönderildi</h6>
                    <h2 class="mb-0">@Model.SentNotifications</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-warning text-white shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-uppercase mb-2">Beklemede</h6>
                    <h2 class="mb-0">@Model.PendingNotifications</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-uppercase mb-2">Başarı Oranı</h6>
                    <h2 class="mb-0">@Model.SuccessRate%</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card bg-secondary text-white shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-uppercase mb-2">👤 Admin Kullanıcılar</h6>
                    <h2 class="mb-0">@Model.TotalAdminUsers</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card bg-danger text-white shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-uppercase mb-2">📑 Toplam Bölümler</h6>
                    <h2 class="mb-0">@Model.TotalSections</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card bg-purple text-white shadow-sm" style="background-color: #9b59b6 !important;">
                <div class="card-body">
                    <h6 class="card-title text-uppercase mb-2">🎮 Mini Uygulamalar</h6>
                    <h2 class="mb-0">@Model.TotalMiniApps</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- GRAFIK SATIRI -->
    <div class="row mb-4">
        <!-- Günlük İstatistikler -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">📈 Günlük Gönderim İstatistikleri</h5>
                </div>
                <div class="card-body">
                    @if (!Model.DailyStats.Any())
                    {
                        <div class="alert alert-warning mb-0">
                            📊 Henüz günlük veri yok. (DailyStats: @Model.DailyStats.Count adet)
                        </div>
                    }
                    else
                    {
                        <canvas id="dailyChart" height="80"></canvas>
                    }
                </div>
            </div>
        </div>

        <!-- Hedef Kitle Dağılımı -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">👥 Hedef Kitle Dağılımı</h5>
                </div>
                <div class="card-body">
                    @if (!Model.TargetAudienceDistribution.Any())
                    {
                        <div class="alert alert-warning mb-0">
                            👥 Henüz kitle dağılımı yok. (Distribution: @Model.TargetAudienceDistribution.Count adet)
                        </div>
                    }
                    else
                    {
                        <canvas id="audienceChart" height="80"></canvas>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Log İstatistikleri -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">📊 Gönderim Durumu</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-4">
                            <div class="p-3 bg-success rounded mb-2" style="background-color: rgba(25, 135, 84, 0.15) !important;">
                                <h3 class="text-success mb-0" style="font-weight: 700;">@Model.SuccessfulLogs</h3>
                                <small class="text-success" style="font-weight: 600;">✓ Başarılı</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-danger rounded mb-2" style="background-color: rgba(220, 53, 69, 0.15) !important;">
                                <h3 class="text-danger mb-0" style="font-weight: 700;">@Model.FailedLogs</h3>
                                <small class="text-danger" style="font-weight: 600;">✗ Başarısız</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-warning rounded mb-2" style="background-color: rgba(255, 193, 7, 0.15) !important;">
                                <h3 class="text-warning mb-0" style="font-weight: 700;">@Model.TestLogs</h3>
                                <small class="text-warning" style="font-weight: 600;">🧪 Test</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Son Gönderilen Bildirimler -->
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">📌 Son Gönderilen Bildirimler</h5>
                </div>
                <div class="card-body">
                    @if (!Model.RecentNotifications.Any())
                    {
                        <div class="alert alert-info mb-0">
                            Henüz bildirim gösterilecek veri yok.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Başlık</th>
                                        <th>Hedef Kitle</th>
                                        <th>Durum</th>
                                        <th>Oluşturuldu</th>
                                        <th>Gönderildi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var notif in Model.RecentNotifications)
                                    {
                                        <tr>
                                            <td class="fw-bold">@notif.Title</td>
                                            <td>
                                                @switch (notif.TargetAudience)
                                                {
                                                    case "guest":
                                                        <span class="badge bg-warning">Misafirler</span>
                                                        break;
                                                    case "regular":
                                                        <span class="badge bg-info">Kayıtlılar</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">Herkes</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @if (notif.IsSent)
                                                {
                                                    <span class="badge bg-success">✓ Gönderildi</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-dark border">Beklemede</span>
                                                }
                                            </td>
                                            <td class="text-muted small">@notif.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td class="text-muted small">
                                                @if (notif.SentAt.HasValue)
                                                {
                                                    @notif.SentAt.Value.ToString("dd.MM.yyyy HH:mm")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- DEBUG: Model Verileri -->
<div style="display: none;" id="debugData">
    DailyStats: @Model.DailyStats.Count
    TargetAudience: @Model.TargetAudienceDistribution.Count
    SuccessfulLogs: @Model.SuccessfulLogs
    FailedLogs: @Model.FailedLogs
</div>

@section Scripts {
<script>
    console.log('Dashboard Model Verileri:');
    console.log('- DailyStats:', @Model.DailyStats.Count, 'item');
    console.log('- TargetAudienceDistribution:', @Model.TargetAudienceDistribution.Count, 'item');
    console.log('- SuccessfulLogs:', @Model.SuccessfulLogs);
    console.log('- FailedLogs:', @Model.FailedLogs);
    console.log('- Chart object:', typeof Chart);

    // Eğer Chart yüklü değilse hata göster
    if (typeof Chart === 'undefined') {
        console.error('❌ HATA: Chart.js yüklenmemiş!');
    } else {
        console.log('✅ Chart.js başarıyla yüklendi');
    }
</script>

<script>
    // Günlük İstatistikler Grafik
    if (typeof Chart !== 'undefined' && document.getElementById('dailyChart')) {
        const dailyCtx = document.getElementById('dailyChart').getContext('2d');

        // JSON ile güvenli serialize et
        const dailyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyStats.Select(d => d.Date).ToList()));
        const dailyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyStats.Select(d => d.Count).ToList()));

        console.log('Daily Chart Data:', dailyLabels, dailyData);

        new Chart(dailyCtx, {
            type: 'line',
            data: {
                labels: dailyLabels,
                datasets: [{
                    label: 'Gönderilen Bildirimler',
                    data: dailyData,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                pointBackgroundColor: '#0d6efd',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 5,
                pointHoverRadius: 7
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    display: true,
                    position: 'top'
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            }
        }
    });
    } else {
        console.error('❌ Daily Chart Hatası: Canvas veya Chart.js yüklü değil');
    }

    // Hedef Kitle Dağılımı Pie Chart
    if (typeof Chart !== 'undefined' && document.getElementById('audienceChart')) {
        const audienceCtx = document.getElementById('audienceChart').getContext('2d');

        // JSON ile güvenli serialize et
        const audienceLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TargetAudienceDistribution.Keys.ToList()));
        const audienceData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TargetAudienceDistribution.Values.ToList()));

        console.log('Audience Chart Data:', audienceLabels, audienceData);

        new Chart(audienceCtx, {
            type: 'doughnut',
            data: {
                labels: audienceLabels,
                datasets: [{
                    data: audienceData,
                    backgroundColor: [
                        '#0d6efd',
                        '#198754',
                        '#ffc107',
                    '#dc3545',
                    '#6f42c1'
                ],
                borderColor: '#fff',
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'bottom'
                }
            }
        }
        });
    } else {
        console.error('❌ Audience Chart Hatası: Canvas veya Chart.js yüklü değil');
    }
</script>
}

<style>
    .card {
        border: none;
        border-radius: 0.5rem;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }

    .bg-opacity-10 {
        opacity: 0.1;
    }

    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }
</style>
