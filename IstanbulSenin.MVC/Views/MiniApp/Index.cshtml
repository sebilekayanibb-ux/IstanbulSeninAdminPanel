@model IEnumerable<IstanbulSenin.CORE.Entities.MiniAppItem>

@{
    ViewData["Title"] = "Uygulama Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="text-muted mb-0">Toplam <strong>@Model.Count()</strong> adet mini uygulama yönetiliyor.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill">
        <i class="bi bi-plus-lg me-2"></i> Yeni Uygulama Ekle
    </a>
</div>

@Html.AntiForgeryToken()

<div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 20px;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-3 py-3" style="width: 40px;"></th>
                    <th class="ps-2 py-3">Uygulama Bilgisi</th>
                    <th class="py-3">Bağlı Bölümler</th>
                    <th class="py-3 text-center">İzinler & Pluginler</th>
                    <th class="py-3 text-center">Durum</th>
                    <th class="py-3 text-center">Sıra</th>
                    <th class="py-3 text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody id="sortable-apps">
                @foreach (var app in Model)
                {
                    <tr data-id="@app.Id">
                        <td class="ps-3 drag-handle" style="cursor: grab; color: #ccc; width: 40px;">
                            <i class="bi bi-grip-vertical fs-5"></i>
                        </td>
                        <td class="ps-2">
                            <div class="d-flex align-items-center">
                                <div class="me-3">
                                    <img src="@(string.IsNullOrEmpty(app.Image) ? "/img/default-app.png" : app.Image)"
                                         class="rounded-4 border shadow-sm"
                                         width="50" height="50" style="object-fit: cover;" />
                                </div>
                                <div>
                                    <div class="fw-bold text-dark">@app.Title</div>
                                    <small class="text-muted d-block" style="font-size: 0.75rem;">URL: @app.Url</small>
                                </div>
                            </div>
                        </td>

                        <td>
                            @if (app.Sections != null && app.Sections.Any())
                            {
                                foreach (var item in app.Sections)
                                {
                                    <span class="badge rounded-pill bg-light text-primary border border-primary border-opacity-10 mb-1" style="font-size: 0.7rem;">
                                        @item.Title
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small italic">Atanmamış</span>
                            }
                        </td>

                        <td class="text-center">
                            <div class="d-flex flex-column gap-1 align-items-center">
                                <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size: 0.65rem;">
                                    <i class="bi bi-shield-lock me-1"></i> @app.Permissions.Count İzin
                                </span>
                                <span class="badge bg-info bg-opacity-10 text-info" style="font-size: 0.65rem;">
                                    <i class="bi bi-plugin me-1"></i> @app.Plugins.Count Plugin
                                </span>
                            </div>
                        </td>

                        <td class="text-center">
                            <div class="d-flex flex-wrap justify-content-center gap-1">
                                @if (app.IsNative) { <span class="badge bg-dark rounded-pill" style="font-size: 0.65rem;">NATIVE</span> }
                                @if (app.IsTest) { <span class="badge bg-warning text-dark rounded-pill" style="font-size: 0.65rem;">TEST</span> }
                                @if (app.IsHide) { <span class="badge bg-danger rounded-pill" style="font-size: 0.65rem;">GİZLİ</span> }
                                @if (!app.IsTest && !app.IsHide) { <span class="badge bg-success rounded-pill" style="font-size: 0.65rem;">AKTİF</span> }
                            </div>
                        </td>

                        <td class="text-center">
                            <span class="fw-bold text-primary order-badge">@app.DisplayOrder</span>
                        </td>

                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm rounded-pill overflow-hidden" style="border: 1px solid #eee;">
                                <a asp-action="Edit" asp-route-id="@app.Id" class="btn btn-white btn-sm px-3" title="Düzenle">
                                    <i class="bi bi-pencil-square text-primary"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@app.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('@app.Title uygulamasını silmek istediğinize emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-white btn-sm px-3" title="Sil">
                                        <i class="bi bi-trash3 text-danger"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .table thead th {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 0.5px;
        color: #8898aa;
        border: none;
    }
    .table tbody td {
        border-bottom: 1px solid #f8f9fa;
        padding-top: 1rem;
        padding-bottom: 1rem;
    }
    .btn-white { background: white; transition: 0.2s; }
    .btn-white:hover { background: #fdf2f7; }
    .badge { letter-spacing: 0.02em; }
    .drag-handle:hover { color: #aaa !important; }
    .sortable-ghost { opacity: 0.4; background: #f0f4ff; }
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.3/Sortable.min.js"></script>
<script>
    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

    new Sortable(document.getElementById('sortable-apps'), {
        handle: '.drag-handle',
        animation: 150,
        ghostClass: 'sortable-ghost',
        onEnd: function () {
            const rows = document.querySelectorAll('#sortable-apps tr[data-id]');
            const ids = Array.from(rows).map(r => parseInt(r.dataset.id));

            rows.forEach((row, index) => {
                row.querySelector('.order-badge').textContent = index + 1;
            });

            fetch('/MiniApp/Reorder', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(ids)
            });
        }
    });
</script>
