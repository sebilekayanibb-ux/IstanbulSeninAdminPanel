@model IstanbulSenin.CORE.Entities.Notification
@{
    ViewData["Title"] = "Bildirim Düzenle";
}

<div class="card border-0 shadow-sm p-4 rounded-4" style="max-width: 680px;">
    <form asp-action="Edit" asp-route-id="@Model.Id">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger rounded-3 small py-2 mb-4">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <input type="hidden" name="id" value="@Model.Id" />

        <div class="mb-3">
            <label asp-for="Title" class="form-label fw-bold small">Başlık</label>
            <input asp-for="Title" class="form-control rounded-3" placeholder="Örn: Yeni Güncelleme" />
            <span asp-validation-for="Title" class="text-danger small fw-bold mt-1 d-block"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Body" class="form-label fw-bold small">İçerik</label>
            <textarea asp-for="Body" class="form-control rounded-3" rows="4"
                      placeholder="Kullanıcılara gösterilecek bildirim metni..."></textarea>
            <span asp-validation-for="Body" class="text-danger small fw-bold mt-1 d-block"></span>
        </div>

        <div class="mb-4">
            <label asp-for="TargetAudience" class="form-label fw-bold small">Hedef Kitle</label>
            <select asp-for="TargetAudience" class="form-select rounded-3">
                <option value="all">Herkes</option>
                <option value="guest">Misafir kullanıcılar</option>
                <option value="regular">Kayıtlı kullanıcılar</option>
            </select>
        </div>

        <div class="mb-4">
            <label asp-for="IsTestMode" class="form-label fw-bold small">Gönderim Modu</label>
            <select asp-for="IsTestMode" class="form-select rounded-3">
                <option value="true">🧪 Test Modunda Gönder</option>
                <option value="false">📤 Gerçek Gönderim Yap</option>
            </select>
            <small class="d-block text-muted mt-1">
                ✓ Test = Logs'ta "Test" olarak gösterilir, başarı oranına katılmaz<br>
                ✓ Gerçek = Logs'ta "Success" olarak gösterilir, başarı oranına katılır
            </small>
        </div>

        <div class="d-flex gap-2 justify-content-end">
            <a asp-action="Index" class="btn btn-light px-4 rounded-pill">Vazgeç</a>
            <button type="submit" class="btn btn-primary px-5 rounded-pill fw-bold shadow-sm">Güncelle</button>
        </div>
    </form>
</div>