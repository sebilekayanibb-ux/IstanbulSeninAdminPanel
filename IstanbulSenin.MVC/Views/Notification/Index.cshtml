@model List<IstanbulSenin.CORE.Entities.Notification>
@{
    ViewData["Title"] = "Bildirimler";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success rounded-3 small py-2 mb-4">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger rounded-3 small py-2 mb-4">@TempData["Error"]</div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted mb-0">Toplam <strong>@Model.Count</strong> bildirim</p>
    <div>
        <a asp-action="Logs" class="btn btn-outline-secondary rounded-pill px-4 fw-bold shadow-sm me-2">
            <i class="bi bi-clock-history me-2"></i>Gönderme Geçmişi
        </a>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Yeni Bildirim
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Başlık</th>
                    <th>İçerik</th>
                    <th>Hedef Kitle</th>
                    <th>Oluşturuldu</th>
                    <th>Durum</th>
                    <th class="text-end pe-4">İşlemler</th
                    >
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="bi bi-bell-slash" style="font-size: 2rem;"></i>
                            <p class="mt-2 mb-0">Henüz bildirim oluşturulmadı.</p>
                        </td>
                    </tr>
                }
                @foreach (var n in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@n.Title</td>
                        <td class="text-muted" style="max-width:250px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@n.Body</td>
                        <td>
                            @{
                                var (label, cls) = n.TargetAudience switch
                                {
                                    "guest" => ("Misafir", "bg-warning text-dark"),
                                    "regular" => ("Kayıtlı", "bg-info text-dark"),
                                    _ => ("Herkes", "bg-secondary")
                                };
                            }
                            <span class="badge @cls">@label</span>
                        </td>
                        <td class="text-muted small">@n.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @if (n.IsSent)
                            {
                                <span class="badge bg-success">Gönderildi</span>
                                <div class="text-muted" style="font-size:0.7rem;">@n.SentAt?.ToString("dd.MM.yyyy HH:mm")</div>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border">Beklemede</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex gap-2 justify-content-end">
                                @if (!n.IsSent)
                                {
                                    <a href="@Url.Action("Edit", new { id = n.Id })" 
                                       class="btn btn-sm btn-outline-warning rounded-pill px-3">
                                        <i class="bi bi-pencil me-1"></i>Düzenle
                                    </a>
                                    <form asp-action="Send" method="post" style="display: inline;">
                                        <input type="hidden" name="id" value="@n.Id" />
                                        <button type="submit" class="btn btn-sm btn-success rounded-pill px-3"
                                                onclick="return confirm('Bildirim gönderilsin mi?')">
                                            <i class="bi bi-send me-1"></i>Gönder
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <a href="@Url.Action("NotificationLogs", new { notificationId = n.Id })" 
                                       class="btn btn-sm btn-outline-info rounded-pill px-3">
                                        <i class="bi bi-eye me-1"></i>Log
                                    </a>
                                }
                                <form asp-action="Delete" method="post" style="display: inline;">
                                    <input type="hidden" name="id" value="@n.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                            onclick="return confirm('Bildirim silinsin mi?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
