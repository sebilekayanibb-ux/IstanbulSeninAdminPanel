@model IstanbulSenin.CORE.Entities.QRCode
@using IstanbulSenin.CORE.Entities

@{
    ViewData["Title"] = "QR Kod Detayları";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-qr-code"></i> QR Kod Detayları
                    </h4>
                </div>
                <div class="card-body">
                    <!-- QR Kod Değeri -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <label class="form-label fw-bold">QR Kod:</label>
                            <div class="input-group mb-2">
                                <input type="text" class="form-control bg-light" value="@Model.Code" readonly>
                                <button class="btn btn-outline-secondary" type="button" 
                                        onclick="copyToClipboard('@Model.Code')" title="Kopyala">
                                    <i class="bi bi-clipboard"></i> Kopyala
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Temel Bilgiler -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Kullanıcı:</label>
                            <p>@(Model.User?.UserName ?? "Silinmiş Kullanıcı")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Durum:</label>
                            <p>
                                @switch (Model.Status)
                                {
                                    case QRCodeStatus.Active:
                                        <span class="badge bg-success">Aktif</span>
                                        break;
                                    case QRCodeStatus.Used:
                                        <span class="badge bg-info">Kullanıldı</span>
                                        break;
                                    case QRCodeStatus.Expired:
                                        <span class="badge bg-warning">Süresi Doldu</span>
                                        break;
                                    case QRCodeStatus.Cancelled:
                                        <span class="badge bg-danger">İptal Edildi</span>
                                        break;
                                }
                            </p>
                        </div>
                    </div>

                    <!-- Açıklama -->
                    <div class="mb-4">
                        <label class="form-label fw-bold">Açıklama:</label>
                        <p>@Model.Description</p>
                    </div>

                    <!-- Zaman Bilgileri -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Oluşturuldu:</label>
                            <p>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Bitiş Tarihi:</label>
                            <p>
                                @Model.ExpiresAt.ToString("dd.MM.yyyy HH:mm:ss")
                                @if (DateTime.UtcNow > Model.ExpiresAt)
                                {
                                    <span class="badge bg-warning">Süresi Dolmuş</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Geçerli</span>
                                }
                            </p>
                        </div>
                    </div>

                    <!-- Kullanım Bilgileri -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <label class="form-label fw-bold">Kullanım Bilgileri:</label>
                            @if (Model.IsUsed && Model.UsedAt.HasValue)
                            {
                                <div class="alert alert-info">
                                    <p class="mb-1">
                                        <strong>Kullanıldı:</strong> @Model.UsedAt.Value.ToString("dd.MM.yyyy HH:mm:ss")
                                    </p>
                                    @if (!string.IsNullOrEmpty(Model.UsedByIp))
                                    {
                                        <p class="mb-0">
                                            <strong>İP Adresi:</strong> @Model.UsedByIp
                                        </p>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning">
                                    <p class="mb-0">Bu QR kod henüz kullanılmamıştır.</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Admin Bilgisi -->
                    @if (!string.IsNullOrEmpty(Model.CreatedByAdmin))
                    {
                        <div class="mb-4">
                            <label class="form-label fw-bold">Oluşturan Admin:</label>
                            <p>@Model.CreatedByAdmin</p>
                        </div>
                    }

                    <!-- Butonlar -->
                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Geri Dön
                        </a>
                        @if (Model.Status == QRCodeStatus.Active)
                        {
                            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" style="display:inline;" 
                                  onsubmit="return confirm('Bu QR kodu iptal etmek istiyor musunuz?');">
                                <button type="submit" class="btn btn-danger">
                                    <i class="bi bi-x-circle"></i> İptal Et
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>

            <!-- QR Kod Bilgi Kutusu -->
            <div class="alert alert-info" role="alert">
                <h6 class="alert-heading">
                    <i class="bi bi-info-circle"></i> QR Kod Durumları
                </h6>
                <small>
                    <ul class="mb-0">
                        <li><strong>Aktif:</strong> QR kod kullanıma hazır ve geçerlilik süresi içindedir.</li>
                        <li><strong>Kullanıldı:</strong> QR kod başarıyla taranmış ve kullanılmıştır.</li>
                        <li><strong>Süresi Doldu:</strong> QR kod geçerlilik süresini aşmıştır.</li>
                        <li><strong>İptal Edildi:</strong> QR kod admin tarafından iptal edilmiştir.</li>
                    </ul>
                </small>
            </div>
        </div>
    </div>
</div>

<script>
    function copyToClipboard(text) {
        navigator.clipboard.writeText(text).then(function () {
            alert('QR kod kopyalandı!');
        }).catch(function (err) {
            console.error('Kopyalama hatası:', err);
        });
    }
</script>
