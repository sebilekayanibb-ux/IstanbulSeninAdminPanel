@model List<IstanbulSenin.CORE.Entities.QRCode>

@{
    ViewData["Title"] = "QR Kodlar";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>QR Kodlar</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Yeni QR Kod Oluştur
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Henüz hiç QR kod oluşturulmamıştır.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Kod</th>
                        <th>Kullanıcı</th>
                        <th>Açıklama</th>
                        <th>Durum</th>
                        <th>Oluşturuldu</th>
                        <th>Bitiş</th>
                        <th>Kullanıldı</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var qr in Model)
                    {
                        <tr>
                            <td>
                                <code class="bg-light p-2" style="font-size: 0.85rem;">@qr.Code</code>
                            </td>
                            <td>
                                @qr.User?.UserName ?? "Silinmiş Kullanıcı"
                            </td>
                            <td>
                                @qr.Description
                            </td>
                            <td>
                                @switch (qr.Status)
                                {
                                    case IstanbulSenin.CORE.Entities.QRCodeStatus.Active:
                                        <span class="badge bg-success">Aktif</span>
                                        break;
                                    case IstanbulSenin.CORE.Entities.QRCodeStatus.Used:
                                        <span class="badge bg-info">Kullanıldı</span>
                                        break;
                                    case IstanbulSenin.CORE.Entities.QRCodeStatus.Expired:
                                        <span class="badge bg-warning">Süresi Doldu</span>
                                        break;
                                    case IstanbulSenin.CORE.Entities.QRCodeStatus.Cancelled:
                                        <span class="badge bg-danger">İptal Edildi</span>
                                        break;
                                }
                            </td>
                            <td>
                                @qr.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </td>
                            <td>
                                @qr.ExpiresAt.ToString("dd.MM.yyyy HH:mm")
                            </td>
                            <td>
                                @if (qr.IsUsed && qr.UsedAt.HasValue)
                                {
                                    <small class="text-muted">
                                        @qr.UsedAt.Value.ToString("dd.MM.yyyy HH:mm")
                                        @if (!string.IsNullOrEmpty(qr.UsedByIp))
                                        {
                                            <br /><em>IP: @qr.UsedByIp</em>
                                        }
                                    </small>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@qr.Id" class="btn btn-sm btn-info" title="Detaylar">
                                    <i class="bi bi-eye"></i> Detay
                                </a>
                                @if (qr.Status == IstanbulSenin.CORE.Entities.QRCodeStatus.Active)
                                {
                                    <form asp-action="Cancel" asp-route-id="@qr.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu QR kodu iptal etmek istiyor musunuz?');">
                                        <button type="submit" class="btn btn-sm btn-danger" title="İptal Et">
                                            <i class="bi bi-x-circle"></i> İptal
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }
</style>
