@model ErrorViewModel
@{
    ViewData["Title"] = "500 - Sunucu Hatası";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h1 class="display-1 fw-bold" style="color: #FF007A;">500</h1>
            <h2>Sunucu Hatası</h2>
            <p class="lead text-muted mt-3">Bir şey yanlış gitti. Lütfen daha sonra tekrar deneyin.</p>

            @if (Model.ShowRequestId)
            {
                <p class="text-muted small mt-3">
                    <strong>Request ID:</strong> <code>@Model.RequestId</code>
                </p>
            }

            <div class="mt-4">
                <a href="@Url.Action("Index", "Dashboard")" class="btn btn-primary">
                    <i class="bi bi-house-fill me-2"></i>Ana Sayfaya Dön
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
    }
</style>
