<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - İstanbul Senin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">

    <!-- ✅ SECURITY: Obfuscation & Console Protection -->
    <script src="~/js/security-obfuscation.js"></script>
    <!-- ✅ SECURITY: Advanced Frontend Protection -->
    <script src="~/js/advanced-security.js"></script>
    <style>
        :root {
            --brand-vibrant: #FF007A;
            --sidebar-width: 280px;
            --sidebar-collapsed-width: 85px;
            --body-bg: #f4f7fe;
            --transition-speed: 0.3s;
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: var(--body-bg); 
            overflow-x: hidden;
        }
        
        /* Sidebar Temel Yapı */
        #sidebar { 
            height: 100vh; 
            background: #ffffff; 
            width: var(--sidebar-width); 
            position: fixed; 
            border-right: 1px solid #EFEFEF;
            transition: width var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            overflow: hidden; /* Taşmayı engeller */
        }

        /* Kapalı Sidebar Genişliği */
        #sidebar.collapsed { width: var(--sidebar-collapsed-width); }

        /* Sidebar Logo ve İçerideki Toggle Butonu */
        .sidebar-header {
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-height: 80px;
        }

        .brand-wrapper {
            display: flex;
            align-items: center;
            white-space: nowrap;
            overflow: hidden;
            font-weight: 800;
            font-size: 1.2rem;
        }

        /* Menü İçindeki Toggle Butonu */
        #inner-toggle {
            background: #FDF2F7;
            border: none;
            color: var(--brand-vibrant);
            border-radius: 10px;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            flex-shrink: 0; /* Butonun ezilmesini engeller */
        }
        #inner-toggle:hover { background: var(--brand-vibrant); color: white; }

        /* Navigasyon Linkleri */
        .nav-link { 
            color: #6F767E; 
            padding: 14px 22px; 
            border-radius: 14px; 
            margin: 4px 15px;
            font-weight: 600;
            display: flex;
            align-items: center;
            text-decoration: none;
            transition: all 0.2s;
            white-space: nowrap; /* Metnin aşağı kaymasını engeller */
        }

        .nav-link i { font-size: 1.4rem; min-width: 40px; display: flex; align-items: center; }
        
        /* Metni Gizleme */
        .nav-link span { 
            opacity: 1;
            transition: opacity 0.2s;
        }

        #sidebar.collapsed .nav-link span,
        #sidebar.collapsed .brand-wrapper span { 
            opacity: 0; 
            display: none; /* Taşmayı tamamen kesmek için */
        }

        .nav-link.active { 
            background: var(--brand-vibrant); 
            color: white !important; 
            box-shadow: 0 10px 20px rgba(255, 0, 122, 0.2); 
        }

        /* İçerik Alanı */
        #main-wrapper { 
            margin-left: var(--sidebar-width); 
            padding: 40px; 
            transition: margin-left var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
        }
        #main-wrapper.expanded { margin-left: var(--sidebar-collapsed-width); }

        /* Profil Kısmı */
        .user-info {
            padding: 20px;
            border-top: 1px solid #F4F4F4;
            display: flex;
            align-items: center;
            min-height: 80px;
        }
        #sidebar.collapsed .user-info .details { display: none; }
    </style>
</head>
<body>

    <aside id="sidebar">
        <div class="sidebar-header">
            <div class="brand-wrapper">
                <i class="bi bi-geo-alt-fill text-pink me-2" style="color: var(--brand-vibrant); font-size: 1.5rem;"></i>
                <span>İSTANBUL SENİN</span>
            </div>
            <button id="inner-toggle">
                <i class="bi bi-list"></i>
            </button>
        </div>
        
        <nav class="nav flex-column mt-2">
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Section" ? "active" : "")" asp-controller="Section" asp-action="Index">
                <i class="bi bi-layers"></i> <span>Bölümler</span>
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "MiniApp" ? "active" : "")" asp-controller="MiniApp" asp-action="Index">
                <i class="bi bi-app-indicator"></i> <span>Uygulamalar</span>
            </a>
            @if (User.IsInRole("SuperAdmin"))
            {
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminUser" ? "active" : "")" asp-controller="AdminUser" asp-action="Index">
                    <i class="bi bi-people"></i> <span>Kullanıcılar</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Notification" ? "active" : "")" asp-controller="Notification" asp-action="Index">
                    <i class="bi bi-bell"></i> <span>Bildirimler</span>
                </a>
            }
        </nav>

        <div class="user-info mt-auto">
            @{
                var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "?";
                var initial = fullName.FirstOrDefault().ToString().ToUpper();
            }
            <div class="avatar bg-light rounded-circle d-flex align-items-center justify-content-center fw-bold"
                 style="min-width: 45px; height: 45px; color: var(--brand-vibrant);">
                @initial
            </div>
            <div class="details ms-3 overflow-hidden">
                <div class="fw-bold text-truncate" style="font-size: 0.85rem; max-width: 140px;">
                    @fullName
                </div>
                <div class="text-muted" style="font-size: 0.7rem;">
                    @(User.IsInRole("SuperAdmin") ? "Super Admin" : "Admin")
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="mt-1">
                    <button type="submit" class="btn btn-link p-0 text-danger fw-bold"
                            style="font-size: 0.7rem; text-decoration: none;">
                        <i class="bi bi-box-arrow-right me-1"></i>Çıkış
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <div id="main-wrapper">
        <header class="mb-5">
            <h2 class="fw-800" style="font-size: 1.8rem; color: #1A1D1F;">@ViewData["Title"]</h2>
        </header>

        <section class="content">
            @RenderBody()
        </section>
    </div>

    <!-- ✅ LOADING SPINNER -->
    <div id="loadingSpinner" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; display:flex; align-items:center; justify-content:center;">
        <div class="text-white text-center">
            <div class="spinner-border mb-3" role="status" style="width:3rem; height:3rem; border-color: #FF007A; border-right-color: transparent;">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
            <p class="fw-bold">Yükleniyor...</p>
        </div>
    </div>

    <div id="toastContainer" class="toast-container position-fixed bottom-0 end-0 p-3"></div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // ✅ LOADING SPINNER HELPER (Sayfa load'da kapatmak için early tanımlama)
        window.showLoading = function () {
            $('#loadingSpinner').fadeIn(200);
        };

        window.hideLoading = function () {
            $('#loadingSpinner').fadeOut(200);
        };

        $(window).on('load', function () {
            window.hideLoading();
        });

        $(document).ready(function () {
            // ✅ Sayfa yüklenmesinde menü durumunu geri yükle (localStorage'den)
            function restoreSidebarState() {
                const isCollapsed = localStorage.getItem("sidebarCollapsed") === "true";
                if (isCollapsed) {
                    $("#sidebar").addClass("collapsed");
                    $("#main-wrapper").addClass("expanded");
                } else {
                    $("#sidebar").removeClass("collapsed");
                    $("#main-wrapper").removeClass("expanded");
                }
            }

            restoreSidebarState();

            window.hideLoading();

            // Menü toggle butonu - localStorage'e kaydet
            $("#inner-toggle").click(function () {
                $("#sidebar").toggleClass("collapsed");
                $("#main-wrapper").toggleClass("expanded");

                const isNowCollapsed = $("#sidebar").hasClass("collapsed");
                localStorage.setItem("sidebarCollapsed", isNowCollapsed);
            });

            $(".nav-link").click(function () {
                if (window.innerWidth < 992) {  
                    $("#sidebar").addClass("collapsed");
                    $("#main-wrapper").addClass("expanded");
                    localStorage.setItem("sidebarCollapsed", "true");
                }
            });

            // ✅ TOAST NOTIFICATION HELPER
            window.showToast = function (message, type = 'success', duration = 5000) {
                const toastId = 'toast-' + Date.now();
                const bgClass = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : 'bg-warning';
                const icon = type === 'success' ? '✓' : type === 'error' ? '✗' : '⚠️';

                const toastHTML = `
                    <div id="${toastId}" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="toast-header ${bgClass} text-white">
                            <strong class="me-auto">${icon} ${type === 'success' ? 'Başarılı' : type === 'error' ? 'Hata' : 'Uyarı'}</strong>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                        </div>
                        <div class="toast-body">
                            ${message}
                        </div>
                    </div>
                `;

                $('#toastContainer').append(toastHTML);
                const toastElement = document.getElementById(toastId);
                const toast = new bootstrap.Toast(toastElement);
                toast.show();

                // Otomatik kapat
                setTimeout(() => {
                    toastElement.remove();
                }, duration);
            };

            // ✅ Form submit'te otomatik spinner göster ve hide et
            $('form').on('submit', function (e) {
                const excludeSpinner = $(this).data('no-spinner') === true;
                if (!excludeSpinner) {
                    window.showLoading();

                    // Form gönderiminden sonra 2 saniye içinde spinner'ı gizle (fallback)
                    setTimeout(() => {
                        window.hideLoading();
                    }, 3000);
                }
            });

            // ✅ AJAX isteklerinde spinner kontrolü
            $(document).on('ajaxStart', function () {
                window.showLoading();
            }).on('ajaxStop', function () {
                window.hideLoading();
            });

            // ✅ CSRF Token - Tüm AJAX isteklerine otomatik ekle
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            if (token) {
                $.ajaxSetup({
                    headers: {
                        'RequestVerificationToken': token
                    }
                });
            }
        });
    </script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>